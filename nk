#!/usr/bin/env bash
# ============================================
# Nook - SSH jumpbox for humans
# Version: 1.1.0
# ============================================

set -euo pipefail

BRAND_NAME="Nook"
PRIMARY_CMD="nk"
VERSION="1.1.0"

XDG_CONFIG_ROOT="${XDG_CONFIG_HOME:-$HOME/.config}"
CONFIG_DIR="${NOOK_CONFIG_DIR:-$XDG_CONFIG_ROOT/nook}"
CONFIG_FILE="$CONFIG_DIR/servers.conf"
HISTORY_FILE="$CONFIG_DIR/.history"

LEGACY_CONFIG_DIR="$HOME/.ssh-manager"
LEGACY_CONFIG_FILE="$LEGACY_CONFIG_DIR/servers.conf"
LEGACY_HISTORY_FILE="$LEGACY_CONFIG_DIR/.history"

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
PURPLE='\033[0;35m'
BOLD='\033[1m'
DIM='\033[2m'
NC='\033[0m'

print_logo() {
    echo -e "${CYAN}${BOLD}"
    cat <<'EOF'
    _   __            __
   / | / /___  ____  / /__
  /  |/ / __ \/ __ \/ //_/
 / /|  / /_/ / /_/ / ,<
/_/ |_/\____/\____/_/|_|
EOF
    echo -e "${NC}${DIM}  SSH jumpbox for humans${NC}"
}

trim_field() {
    local value="$1"
    value="${value#"${value%%[![:space:]]*}"}"
    value="${value%"${value##*[![:space:]]}"}"
    printf '%s' "$value"
}

write_default_config() {
    cat > "$CONFIG_FILE" <<'CONF'
# ============================================
# Nook - server catalog
# ============================================
# Format : name | host | port | user | password(optional) | description
# Group  : lines like [group-name]
# Notes  : password empty means SSH key login
# ============================================

[default]
# prod-web-01 | 1.2.3.4 | 22 | root | yourpass | production web node
CONF
}

migrate_legacy_config() {
    [[ -n "${NOOK_CONFIG_DIR:-}" ]] && return 0

    if [[ -f "$LEGACY_CONFIG_FILE" && ! -f "$CONFIG_FILE" ]]; then
        cp "$LEGACY_CONFIG_FILE" "$CONFIG_FILE"
        echo -e "${DIM}[migrate] imported config from ${LEGACY_CONFIG_FILE}${NC}"
    fi

    if [[ -f "$LEGACY_HISTORY_FILE" && ! -f "$HISTORY_FILE" ]]; then
        cp "$LEGACY_HISTORY_FILE" "$HISTORY_FILE"
        echo -e "${DIM}[migrate] imported history from ${LEGACY_HISTORY_FILE}${NC}"
    fi
}

init() {
    mkdir -p "$CONFIG_DIR"
    migrate_legacy_config

    if [[ ! -f "$CONFIG_FILE" ]]; then
        write_default_config
        echo -e "${YELLOW}[init] created config: ${CONFIG_FILE}${NC}"
        echo -e "${YELLOW}[next] add your first server with: ${PRIMARY_CMD} add${NC}"
    fi

    touch "$HISTORY_FILE"
    chmod 600 "$CONFIG_FILE" "$HISTORY_FILE" 2>/dev/null || true
}

show_help() {
    print_logo
    echo ""
    echo -e "${BOLD}${BRAND_NAME} v${VERSION}${NC}"
    echo ""
    echo -e "${BOLD}Usage${NC}"
    echo -e "  ${GREEN}${PRIMARY_CMD}${NC}              Open the server picker"
    echo -e "  ${GREEN}${PRIMARY_CMD} add${NC}          Add a server"
    echo -e "  ${GREEN}${PRIMARY_CMD} rm${NC}           Remove a server"
    echo -e "  ${GREEN}${PRIMARY_CMD} list${NC}         List all servers"
    echo -e "  ${GREEN}${PRIMARY_CMD} edit${NC}         Edit the config file"
    echo -e "  ${GREEN}${PRIMARY_CMD} key${NC}          Configure SSH key login"
    echo -e "  ${GREEN}${PRIMARY_CMD} ping${NC}         Check server reachability"
    echo -e "  ${GREEN}${PRIMARY_CMD} doctor${NC}       Show environment diagnostics"
    echo -e "  ${GREEN}${PRIMARY_CMD} <keyword>${NC}    Search and connect"
    echo -e "  ${GREEN}${PRIMARY_CMD} version${NC}      Show version"
    echo -e "  ${GREEN}${PRIMARY_CMD} help${NC}         Show this help"
    echo ""
    echo -e "${BOLD}Brand${NC}"
    echo -e "  Primary command : ${PRIMARY_CMD}"
    echo ""
    echo -e "${BOLD}Config${NC}"
    echo -e "  ${CONFIG_FILE}"
}

parse_servers() {
    local group="default"
    while IFS= read -r line; do
        [[ -z "$line" || "$line" =~ ^[[:space:]]*# ]] && continue

        if [[ "$line" =~ ^\[(.+)\]$ ]]; then
            group="${BASH_REMATCH[1]}"
            continue
        fi

        IFS='|' read -r name host port user pass desc <<< "$line"
        name=$(trim_field "$name")
        host=$(trim_field "$host")
        port=$(trim_field "$port")
        user=$(trim_field "$user")
        pass=$(trim_field "${pass:-}")
        desc=$(trim_field "${desc:-}")

        [[ -z "$name" || -z "$host" ]] && continue

        port=${port:-22}
        user=${user:-root}
        echo "${group}|${name}|${host}|${port}|${user}|${pass}|${desc}"
    done < "$CONFIG_FILE"
}

count_servers() {
    [[ -f "$CONFIG_FILE" ]] || {
        echo 0
        return 0
    }

    local servers
    servers=$(parse_servers)
    if [[ -z "$servers" ]]; then
        echo 0
    else
        printf '%s\n' "$servers" | awk 'END { print NR }'
    fi
}

record_history() {
    local name="$1"
    local tmp
    tmp=$(mktemp)
    echo "$name" > "$tmp"
    grep -Fvx "$name" "$HISTORY_FILE" >> "$tmp" 2>/dev/null || true
    head -20 "$tmp" > "$HISTORY_FILE"
    rm -f "$tmp"
}

connect_server() {
    local host="$1" port="$2" user="$3" name="$4" pass="${5:-}"
    record_history "$name"
    echo -e "${GREEN}[connect]${NC} ${BOLD}${name}${NC} ${DIM}${user}@${host}:${port}${NC}"
    echo ""

    local ssh_opts=(
        -o ConnectTimeout=10
        -o ServerAliveInterval=60
        -o ServerAliveCountMax=3
        -o StrictHostKeyChecking=accept-new
        -p "$port"
    )

    if [[ -n "$pass" ]] && command -v sshpass >/dev/null 2>&1; then
        sshpass -p "$pass" ssh "${ssh_opts[@]}" "${user}@${host}"
    else
        ssh "${ssh_opts[@]}" "${user}@${host}"
    fi
}

select_with_fzf() {
    local filter="${1:-}"
    local servers
    servers=$(parse_servers)
    [[ -z "$servers" ]] && echo -e "${RED}[x] no servers configured, run: ${PRIMARY_CMD} add${NC}" && return 1

    local fzf_input="" idx=0
    while IFS='|' read -r group name host port user pass desc; do
        idx=$((idx + 1))
        local auth="key"
        [[ -n "$pass" ]] && auth="pwd"
        printf -v line " %2d  %-18s  %-16s  %-5s  %-8s  %-4s  %-10s  %s" \
            "$idx" "$name" "$host" "$port" "$user" "$auth" "$group" "$desc"
        fzf_input+="${line}"$'\n'
    done <<< "$servers"

    local header brand_line
    brand_line=" Nook  |  SSH jumpbox for humans  |  ${PRIMARY_CMD} add | ${PRIMARY_CMD} key | ${PRIMARY_CMD} ping"
    printf -v header " %-3s  %-18s  %-16s  %-5s  %-8s  %-4s  %-10s  %s" \
        "#" "Name" "Host" "Port" "User" "Auth" "Group" "Note"

    local selected
    selected=$(printf '%s' "$fzf_input" | \
        fzf --ansi \
            --header="${brand_line}"$'\n'"${header}" \
            --prompt=" ${PRIMARY_CMD} > " \
            --height=~60% \
            --layout=reverse \
            --border=rounded \
            --border-label=" Nook " \
            --border-label-pos=3 \
            --query="$filter" \
            --preview-window=hidden \
            --pointer=">" \
            --marker="*" \
            --color=header:italic,info:dim,pointer:green,marker:yellow,border:cyan,prompt:cyan,hl:green,hl+:green \
        2>/dev/null) || return 1

    [[ -z "$selected" ]] && return 1

    local sel_idx
    sel_idx=$(printf '%s\n' "$selected" | awk '{print $1}')
    idx=0
    while IFS='|' read -r group name host port user pass desc; do
        idx=$((idx + 1))
        if [[ "$idx" == "$sel_idx" ]]; then
            echo "${name}|${host}|${port}|${user}|${pass}"
            return 0
        fi
    done <<< "$servers"
}

select_fallback() {
    local filter="${1:-}"
    local servers
    servers=$(parse_servers)
    [[ -z "$servers" ]] && echo -e "${RED}[x] no servers configured, run: ${PRIMARY_CMD} add${NC}" && return 1

    print_logo
    echo ""
    echo -e "${DIM}Config: ${CONFIG_FILE}${NC}"
    echo ""

    local -a names=() hosts=() ports=() users=() passes=()
    local current_group="" idx=0
    while IFS='|' read -r group name host port user pass desc; do
        if [[ -n "$filter" ]] && ! printf '%s\n' "$name $host $desc $group" | grep -Fqi "$filter"; then
            continue
        fi

        if [[ "$current_group" != "$group" ]]; then
            current_group="$group"
            echo -e "  ${PURPLE}${BOLD}[$group]${NC}"
        fi

        idx=$((idx + 1))
        names+=("$name")
        hosts+=("$host")
        ports+=("$port")
        users+=("$user")
        passes+=("$pass")

        local auth="key"
        [[ -n "$pass" ]] && auth="pwd"
        printf "  ${GREEN}%3d)${NC} %-18s ${DIM}%-16s :%-5s %-8s${NC} %-4s %s\n" \
            "$idx" "$name" "$host" "$port" "$user" "$auth" "$desc"
    done <<< "$servers"

    [[ $idx -eq 0 ]] && echo -e "${RED}[x] no server matched your filter${NC}" && return 1

    echo ""
    read -r -p "$(echo -e "${BOLD}Pick [1-${idx}]: ${NC}")" choice
    if [[ "$choice" =~ ^[0-9]+$ ]] && (( choice >= 1 && choice <= idx )); then
        local i=$((choice - 1))
        echo "${names[$i]}|${hosts[$i]}|${ports[$i]}|${users[$i]}|${passes[$i]}"
    else
        echo -e "${RED}[x] invalid selection${NC}" && return 1
    fi
}

insert_entry_into_group() {
    local group="$1" entry="$2"
    local tmp
    tmp=$(mktemp)

    awk -v group="$group" -v entry="$entry" '
        BEGIN { inserted = 0 }
        {
            print
            if ($0 == "[" group "]" && inserted == 0) {
                print entry
                inserted = 1
            }
        }
        END {
            if (inserted == 0) {
                if (NR > 0) {
                    print ""
                }
                print "[" group "]"
                print entry
            }
        }
    ' "$CONFIG_FILE" > "$tmp"

    mv "$tmp" "$CONFIG_FILE"
}

delete_entry_from_config() {
    local target_name="$1"
    local tmp
    tmp=$(mktemp)

    awk -F'|' -v target_name="$target_name" '
        function trim(value) {
            gsub(/^[[:space:]]+|[[:space:]]+$/, "", value)
            return value
        }
        /^[[:space:]]*$/ { print; next }
        /^[[:space:]]*#/ { print; next }
        /^\[/ { print; next }
        {
            candidate = trim($1)
            if (candidate != target_name) {
                print
            }
        }
    ' "$CONFIG_FILE" > "$tmp"

    mv "$tmp" "$CONFIG_FILE"
}

cmd_add() {
    print_logo
    echo ""
    echo -e "${BOLD}Add a server${NC}"
    echo ""

    read -r -p "$(echo -e "${BOLD}Name: ${NC}")" name
    [[ -z "$name" ]] && echo -e "${RED}[x] name cannot be empty${NC}" && return 1

    read -r -p "$(echo -e "${BOLD}Host: ${NC}")" host
    [[ -z "$host" ]] && echo -e "${RED}[x] host cannot be empty${NC}" && return 1

    read -r -p "$(echo -e "${BOLD}Port [22]: ${NC}")" port
    port=${port:-22}

    read -r -p "$(echo -e "${BOLD}User [root]: ${NC}")" user
    user=${user:-root}

    read -r -s -p "$(echo -e "${BOLD}Password (blank for SSH key): ${NC}")" pass
    echo ""

    read -r -p "$(echo -e "${BOLD}Note: ${NC}")" desc

    local groups=()
    while IFS= read -r line; do
        if [[ "$line" =~ ^\[(.+)\]$ ]]; then
            groups+=("${BASH_REMATCH[1]}")
        fi
    done < "$CONFIG_FILE"

    local group=""
    if [[ ${#groups[@]} -gt 0 ]]; then
        echo ""
        echo -e "${BOLD}Group${NC}"
        local i=0
        for g in "${groups[@]}"; do
            i=$((i + 1))
            echo -e "  ${GREEN}${i})${NC} $g"
        done
        echo -e "  ${GREEN}$((i + 1)))${NC} create new group"

        read -r -p "$(echo -e "${BOLD}Pick [1]: ${NC}")" gchoice
        gchoice=${gchoice:-1}
        if (( gchoice > 0 && gchoice <= ${#groups[@]} )); then
            group="${groups[$((gchoice - 1))]}"
        fi
    fi

    if [[ -z "$group" ]]; then
        read -r -p "$(echo -e "${BOLD}New group [default]: ${NC}")" group
        group=${group:-default}
    fi

    local entry
    printf -v entry "%-18s | %-20s | %-5s | %-10s | %-12s | %s" \
        "$name" "$host" "$port" "$user" "$pass" "$desc"
    insert_entry_into_group "$group" "$entry"

    echo ""
    echo -e "${GREEN}[ok]${NC} added ${BOLD}${name}${NC} (${user}@${host}:${port}) in [${group}]"
    echo ""

    read -r -p "$(echo -e "${BOLD}Configure SSH key login now? [y/N]: ${NC}")" setup_key
    if [[ "$setup_key" =~ ^[yY] ]]; then
        setup_ssh_key "$host" "$port" "$user" "$pass"
    fi
}

cmd_rm() {
    local result
    if command -v fzf >/dev/null 2>&1; then
        result=$(select_with_fzf "")
    else
        result=$(select_fallback "")
    fi
    [[ -z "$result" ]] && return 1

    local name host port user
    IFS='|' read -r name host port user <<< "$result"

    read -r -p "$(echo -e "${RED}Remove ${BOLD}${name}${NC}${RED} (${host})? [y/N]: ${NC}")" confirm
    if [[ "$confirm" =~ ^[yY] ]]; then
        delete_entry_from_config "$name"
        echo -e "${GREEN}[ok]${NC} removed ${name}"
    fi
}

cmd_list() {
    local servers
    servers=$(parse_servers)
    [[ -z "$servers" ]] && echo -e "${YELLOW}[warn] no servers configured${NC}" && return 0

    print_logo
    echo ""

    local current_group="" idx=0
    while IFS='|' read -r group name host port user pass desc; do
        if [[ "$current_group" != "$group" ]]; then
            current_group="$group"
            echo -e "  ${PURPLE}${BOLD}[$group]${NC}"
        fi

        idx=$((idx + 1))
        local auth="key"
        [[ -n "$pass" ]] && auth="pwd"
        printf "    ${GREEN}%-18s${NC} ${DIM}%-16s :%-5s %-8s${NC} %-4s %s\n" \
            "$name" "$host" "$port" "$user" "$auth" "$desc"
    done <<< "$servers"

    echo ""
    echo -e "  ${DIM}${idx} server(s)${NC}"
}

cmd_edit() {
    local editor="${EDITOR:-vim}"
    echo -e "${DIM}[edit] opening ${CONFIG_FILE} with ${editor}${NC}"
    "$editor" "$CONFIG_FILE"
}

setup_ssh_key() {
    local host="$1" port="$2" user="$3" pass="${4:-}"
    local key_file="$HOME/.ssh/id_rsa.pub"

    if [[ ! -f "$key_file" ]]; then
        if [[ -f "$HOME/.ssh/id_ed25519.pub" ]]; then
            key_file="$HOME/.ssh/id_ed25519.pub"
        else
            echo -e "${YELLOW}[init] no SSH public key found, generating ed25519...${NC}"
            ssh-keygen -t ed25519 -f "$HOME/.ssh/id_ed25519" -N "" -C "nook@$(hostname)"
            key_file="$HOME/.ssh/id_ed25519.pub"
        fi
    fi

    echo -e "${DIM}[key] pushing ${key_file} to ${user}@${host}:${port}${NC}"
    if [[ -n "$pass" ]] && command -v sshpass >/dev/null 2>&1; then
        sshpass -p "$pass" ssh-copy-id -o StrictHostKeyChecking=accept-new -i "$key_file" -p "$port" "${user}@${host}" 2>/dev/null && \
            echo -e "${GREEN}[ok]${NC} SSH key login configured" || \
            echo -e "${RED}[x] key setup failed, verify connection or password${NC}"
    else
        ssh-copy-id -i "$key_file" -p "$port" "${user}@${host}" 2>/dev/null && \
            echo -e "${GREEN}[ok]${NC} SSH key login configured" || \
            echo -e "${RED}[x] key setup failed, verify connection or complete it manually${NC}"
    fi
}

cmd_key() {
    print_logo
    echo ""
    echo -e "${BOLD}Configure SSH key login${NC}"
    echo ""

    local result
    if command -v fzf >/dev/null 2>&1; then
        result=$(select_with_fzf "")
    else
        result=$(select_fallback "")
    fi
    [[ -z "$result" ]] && return 1

    local name host port user pass
    IFS='|' read -r name host port user pass <<< "$result"
    setup_ssh_key "$host" "$port" "$user" "$pass"
}

cmd_ping() {
    local servers
    servers=$(parse_servers)
    [[ -z "$servers" ]] && echo -e "${YELLOW}[warn] no servers configured${NC}" && return 0

    print_logo
    echo ""
    echo -e "${BOLD}Reachability${NC}"
    echo ""

    while IFS='|' read -r group name host port user pass desc; do
        printf "  %-18s %-16s " "$name" "$host"
        if nc -z -w 3 "$host" "$port" 2>/dev/null; then
            echo -e "${GREEN}[ok] online${NC}"
        else
            echo -e "${RED}[x] offline${NC}"
        fi
    done <<< "$servers"
}

cmd_doctor() {
    local server_count
    server_count=$(count_servers)

    print_logo
    echo ""
    echo -e "${BOLD}Diagnostics${NC}"
    echo ""

    printf "  %-18s %s\n" "Version" "${BRAND_NAME} ${VERSION}"
    printf "  %-18s %s\n" "Primary command" "${PRIMARY_CMD}"
    printf "  %-18s %s\n" "Config dir" "${CONFIG_DIR}"
    printf "  %-18s %s\n" "Config file" "${CONFIG_FILE}"
    printf "  %-18s %s\n" "History file" "${HISTORY_FILE}"
    printf "  %-18s %s\n" "Servers" "${server_count}"
    printf "  %-18s %s\n" "Shell" "${SHELL:-unknown}"

    if command -v bash >/dev/null 2>&1; then
        printf "  %-18s %s\n" "Bash" "$(bash --version | head -1)"
    else
        printf "  %-18s %s\n" "Bash" "not found"
    fi

    if command -v ssh >/dev/null 2>&1; then
        printf "  %-18s %s\n" "SSH" "$(ssh -V 2>&1)"
    else
        printf "  %-18s %s\n" "SSH" "not found"
    fi

    if command -v fzf >/dev/null 2>&1; then
        printf "  %-18s %s\n" "fzf" "$(fzf --version 2>/dev/null | head -1)"
    else
        printf "  %-18s %s\n" "fzf" "not installed"
    fi

    if command -v sshpass >/dev/null 2>&1; then
        printf "  %-18s %s\n" "sshpass" "installed"
    else
        printf "  %-18s %s\n" "sshpass" "not installed"
    fi

    if [[ -f "$CONFIG_FILE" ]]; then
        printf "  %-18s %s\n" "Config status" "present"
    else
        printf "  %-18s %s\n" "Config status" "missing"
    fi
}

main() {
    case "${1:-}" in
        help|--help|-h)
            show_help
            return 0
            ;;
        version|--version|-v)
            echo "${BRAND_NAME} ${VERSION}"
            return 0
            ;;
        doctor|diag|debug)
            cmd_doctor
            return 0
            ;;
        *)
            init
            ;;
    esac

    case "${1:-}" in
        add)
            cmd_add
            ;;
        rm|remove|del|delete)
            cmd_rm
            ;;
        list|ls|l)
            cmd_list
            ;;
        edit)
            cmd_edit
            ;;
        key|keys)
            cmd_key
            ;;
        ping|check)
            cmd_ping
            ;;
        doctor|diag|debug)
            cmd_doctor
            ;;
        "")
            local result
            if command -v fzf >/dev/null 2>&1; then
                result=$(select_with_fzf "")
            else
                result=$(select_fallback "")
            fi
            [[ -z "$result" ]] && exit 0
            local name host port user pass
            IFS='|' read -r name host port user pass <<< "$result"
            connect_server "$host" "$port" "$user" "$name" "$pass"
            ;;
        *)
            local result
            if command -v fzf >/dev/null 2>&1; then
                result=$(select_with_fzf "$1")
            else
                result=$(select_fallback "$1")
            fi
            [[ -z "$result" ]] && exit 0
            local name host port user pass
            IFS='|' read -r name host port user pass <<< "$result"
            connect_server "$host" "$port" "$user" "$name" "$pass"
            ;;
    esac
}

main "$@"
